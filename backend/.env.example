# ==========================================
# 应用配置
# ==========================================
DEBUG=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==========================================
# 阿里云百炼 API 配置
# ==========================================
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_MODEL=qwen-max

# OCR 视觉模型
DASHSCOPE_OCR_MODEL=qwen-vl-max-latest

# ==========================================
# Claude API 配置 (用于夜间/每周任务脚本)
# ==========================================
ANTHROPIC_AUTH_TOKEN=your_anthropic_token_here
ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
ANTHROPIC_MODEL=qwen3.5-plus

# ==========================================
# 通知配置 - 飞书
# ==========================================
FEISHU_NIGHTLY_TASK_GROUP=your_chat_id_here
FEISHU_NEWS_GROUP=your_chat_id_here
FEISHU_API_URL=https://open.feishu.cn/open-apis/im/v1/messages

# ==========================================
# 通知配置 - 微信
# ==========================================
WEIXIN_REPORT_TARGET=your_wechat_id_here

# ==========================================
# 应用 URL 配置
# ==========================================
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
API_DOCS_URL=http://localhost:8000/docs
CLAUDE_APPS_URL=https://claude-apps.com
