# ==========================================
# Resume Optimizer - 环境变量模板
# ==========================================
# 复制此文件为 backend/.env 并填入真实值
# 注意：.env 文件已被 .gitignore 排除，不要上传到 Git
#
# 全局配置（API Keys、群组 ID 等）位于：/home/lisa/.env
# 本项目仅需填写下方项目特定配置
# ==========================================

# ==========================================
# 应用运行配置
# ==========================================
DEBUG=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==========================================
# 项目特定模型配置
# ==========================================
# 简历优化使用 qwen-max 获得更好的理解能力
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_OCR_MODEL=qwen-vl-max-latest

# ==========================================
# 应用 URL 配置
# ==========================================
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
API_DOCS_URL=http://localhost:8000/docs

# ==========================================
# 飞书 API 直接调用配置（可选）
# 如使用 OpenClaw Gateway 则不需要
# ==========================================
FEISHU_API_URL=https://open.feishu.cn/open-apis/im/v1/messages
