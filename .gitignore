# ===========================================
# Resume Optimizer - .gitignore
# ===========================================

# 环境变量和敏感配置
*.env
.env
.env.*
!.env.sample
backend/.env
frontend/.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/venv/
*.pyc

# Node
node_modules/
npm-debug.log
yarn-error.log
frontend/node_modules/

# 构建产物
backend/build/
backend/dist/
backend/*.egg-info/
frontend/build/
frontend/dist/

# 日志
logs/
*.log

# 数据库
*.db
*.sqlite
*.sqlite3

# 上传文件
uploads/
backend/uploads/

# 测试和覆盖率
.pytest_cache/
.coverage
htmlcov/
.nyc_output/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统
.DS_Store
Thumbs.db

# Claude 本地配置
.claude/
CLAUDE.md

# 临时文件
*.tmp
*.bak
